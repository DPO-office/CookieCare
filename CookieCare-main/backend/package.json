{
  "name": "cookiecare-backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/setupDb.ts && esbuild server.ts --bundle --platform=node --format=esm --packages=external --outfile=server.js && node server.js",
    "build": "esbuild server.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/server.js",
    "start": "node dist/server.js",
    "setup-db": "tsx scripts/setupDb.ts",
    "lint": "tsc --noEmit",
    "test": "node --import ./node_modules/tsx/dist/loader.mjs --test test/**/*.test.ts"
  },
  "dependencies": {
    "@google/genai": "^2.11.0",
    "@google/generative-ai": "^0.24.1",
    "@sentry/node": "^10.56.0",
    "@sentry/profiling-node": "^10.56.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "argon2": "^0.44.0",
    "cors": "^2.8.6",
    "docx": "^9.7.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "file-type": "^22.0.1",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "pdf-parse-fork": "^1.2.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.60.0",
    "uuid": "^14.0.0",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "esbuild": "^0.25.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "~5.8.2"
  }
}
